n        // 두 번째 광고에만 좌측 마진 적용하여 광고 사이 간격 조정\n        if (isSecondAd) {\n            ad.style.marginLeft = '20px';\n        }\n\n        document.getElementById('ad-container-2').appendChild(ad);\n        (adsbygoogle = window.adsbygoogle || []).push({});\n    }\n\n    // 화면 너비에 따라 광고 로드\n    var width = window.innerWidth || document.documentElement.clientWidth || document.body.clientWidth;\n\n    // 항상 첫 번째 광고 로드\n    createAd('8610341899', false);\n\n    // 데스크탑 환경에서만 두 번째 광고 로드\n    if (width > 768) { // 768px은 모바일과 데스크탑을 구분하는 일반적인 기준입니다.\n        createAd('5984178559', true);\n    }\n</script>\n\n<script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js\"></script>\n<!--kg-card-end: html-->\n<h3 id=\"2-%EA%B0%84%EC%A0%91%EC%84%B8\">2) 간접세</h3><p>간접세에는 부가가치세, 주세, 인지세, 증권거래세, 개별소비세 등이 있습니다. 실제 세금을 납부하는 사람과 실제로 부담하는 사람이 다른 것을 의미합니다. </p><p>간접세는 납세의무자가 일단 납세를 하고, 그 조세가 물품의 가격에 포함되는 등의 방법에 의하여 조세 부담자에게 전가 예정이 확정 되어 있는 세금이라는 점이 직접세와 다릅니다.</p>\n<!--kg-card-begin: html-->\n<div id=\"ad-container-3\" style=\"display: flex; justify-content: center; flex-wrap: wrap;\"></div>\n\n<script>\n    // 광고를 동적으로 생성하고 페이지에 삽입하는 함수\n    function createAd(slotId, isSecondAd) {\n        var ad = document.createElement('ins');\n        ad.className = 'adsbygoogle';\n        ad.style.display = 'block';\n        ad.style.width = '300px'; // 광고 너비 설정\n        ad.style.height = '250px'; // 광고 높이 설정\n        ad.dataset.adClient = 'ca-pub-1067668052326016';\n        ad.dataset.adSlot = slotId;\n        ad.dataset.adFormat = 'rectangle';\n        ad.dataset.fullWidthResponsive = 'true';\n        ad.style.margin = 'auto';\n\n        // 두 번째 광고에만 좌측 마진 적용하여 광고 사이 간격 조정\n        if (isSecondAd) {\n            ad.style.marginLeft = '20px';\n        }\n\n        document.getElementById('ad-container-3').appendChild(ad);\n        (adsbygoogle = window.adsbygoogle || []).push({});\n    }\n\n    // 화면 너비에 따라 광고 로드\n    var width = window.innerWidth || document.documentElement.clientWidth || document.body.clientWidth;\n\n    // 항상 첫 번째 광고 로드\n    createAd('8610341899', false);\n\n    // 데스크탑 환경에서만 두 번째 광고 로드\n    if (width > 768) { // 768px은 모바일과 데스크탑을 구분하는 일반적인 기준입니다.\n        createAd('5984178559', true);\n    }\n</script>\n\n<script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js\"></script>\n<!--kg-card-end: html-->\n<h3 id=\"3-%EB%AA%A9%EC%A0%81%EC%84%B8\">3) 목적세</h3><p>목적세는 세금의 용도가 명확히 특정된 조세를 말하며, 교육세, 농어촌특별세, 교통/에너지/환경세 등이 있습니다. </p><p>예를 들면 농어촌특별세의 경우 우리나라의 농어업의 경쟁력 강화 및 농어촌산업기반기술의 확충 혹은 개발을 위해 필요한 세수를 확보하기 위한 조세입니다.</p><p>즉, 특정 목적에 지출을 위해 충당하기 위한 조세라고 이해하면 되겠습니다.</p>\n<!--kg-card-begin: html-->\n<script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1067668052326016\"\n     crossorigin=\"anonymous\"></script>\n<!-- github.M.Display.상단 -->\n<ins class=\"adsbygoogle\"\n     style=\"display:block\"\n     data-ad-client=\"ca-pub-1067668052326016\"\n     data-ad-slot=\"7030651089\"\n     data-ad-format=\"auto\"\n     data-full-width-responsive=\"true\"></ins>\n<script>\n     (adsbygoogle = window.adsbygoogle || []).push({});\n</script>\n<!--kg-card-end: html-->\n<h2 id=\"2-%EC%A7%80%EB%B0%A9%EC%84%B8\">2. 지방세</h2><p>지방세는 도세와 시군세로 나누어집니다. 시군세는 모두 보통세로 이루어져 있으며, 도세는 보통세와 목적세로 나누어집니다. </p><figure class=\"kg-card kg-image-card kg-card-hascaption\"><img src=\"https://alwayswithtech.ghost.io/content/images/2024/01/SCR-20240114-nbza.png\" class=\"kg-image\" alt=\"\" loading=\"lazy\" width=\"846\" height=\"520\" srcset=\"https://alwayswithtech.ghost.io/content/images/size/w600/2024/01/SCR-20240114-nbza.png 600w, https://alwayswithtech.ghost.io/content/images/2024/01/SCR-20240114-nbza.png 846w\" sizes=\"(min-width: 720px) 720px\"><figcaption><span style=\"white-space: pre-wrap;\">지방세의 종류</span></figcaption></figure><p>도세의 보통세에는 취득세, 등록면허세, 레저세, 지방소비세 등이 있으며, 목적세는 지역자원시설세, 지방교육세 등이 있습니다. 목적세의 경우 앞에서 말했듯이 특정 목적을 위한 지출을 충당하기 위해 걷어들이는 세금이지만, 보통세는 일반적인 지출을 충당하기 위해 세금을 부과합니다. </p><p>시군세 역시 주민세, 재산세, 자동차세, 지방소득세, 담배소비세 등으로 이루어져 있으며 이들 모두 보통세 입니다. </p>\n<!--kg-card-begin: html-->\n<script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1067668052326016\"\n     crossorigin=\"anonymous\"></script>\n<!-- github.M.Display.상단 -->\n<ins class=\"adsbygoogle\"\n     style=\"display:block\"\n     data-ad-client=\"ca-pub-1067668052326016\"\n     data-ad-slot=\"7030651089\"\n     data-ad-format=\"auto\"\n     data-full-width-responsive=\"true\"></ins>\n<script>\n     (adsbygoogle = window.adsbygoogle || []).push({});\n</script>\n<!--kg-card-end: html-->\n<h2 id=\"%EB%A7%88%EC%B9%98%EB%A9%B0\">마치며</h2><p>국세와 지방세의 차이점에 대해 알아보았습니다. 우리나라 조세 체계를 보면 정말 다양한 세금이 있는 셈입니다. </p><p>선진국으로 가면 갈수록 직접세의 비중이 높아지며, 간접세의 비중이 낮아지는 경향이 있습니다. 우리나라도 한동안은 간접세인 부가세가 가장 높은 비율을 차지하고 있었지만 최근 몇년 전부터는 소득세와 법인세 등이 비중이 높아지고 있고, 이는 우리나라가 조세 체계 상 선진국으로 향해가고 있다는 뜻이 아닐까 생각해봅니다.</p>\n<!--kg-card-begin: html-->\n<script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1067668052326016\"\n     crossorigin=\"anonymous\"></script>\n<ins class=\"adsbygoogle\"\n     style=\"display:block\"\n     data-ad-format=\"autorelaxed\"\n     data-ad-client=\"ca-pub-1067668052326016\"\n     data-ad-slot=\"8256651582\"></ins>\n<script>\n     (adsbygoogle = window.adsbygoogle || []).push({});\n</script>\n<!--kg-card-end: html-->\n","url":"https://alwayswithtech.ghost.io/about-korea-tax/","canonical_url":null,"uuid":"d6c09e83-c4b1-430b-bd2c-b8adff179756","page":null,"codeinjection_foot":null,"codeinjection_head":null,"codeinjection_styles":null,"comment_id":"65a246888fdb4800018418f8","reading_time":7}},"pageContext":{"slug":"about-korea-tax"}},"staticQueryHashes":["1752937443","2358152166","2561578252","2731221146","4145280475"]}